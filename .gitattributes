# Normalize all text files to LF in the repository and on checkout.
# Overrides per-machine core.autocrlf so line endings stay consistent
# across OSes, and matches Prettier's default endOfLine: "lf".
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
